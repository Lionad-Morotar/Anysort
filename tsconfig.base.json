{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@anysort/core": ["./packages/core/types/index.d.ts"],
      "@anysort/core/*": ["./packages/core/types/*"]
    }
  }
}
