{
  "name": "@anysort/core",
  "version": "0.1.0",
  "description": "Flexible and Full Typed multi-properties sorter for nested objects",
  "license": "MIT",
  "type": "module",
  "main": "./build/index.cjs.min.js",
  "module": "./build/index.esm.min.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./build/index.esm.min.js",
      "require": "./build/index.cjs.min.js"
    },
    "./types": "./types/index.d.ts"
  },
  "files": [
    "build/**/*",
    "types/**/*",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "statics/*"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "oxlint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "watch:test": "vitest",
    "coverage:badge": "coverage-badge-creator",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "any",
    "array",
    "multiple",
    "nested",
    "object",
    "order",
    "multi-properties",
    "property",
    "sort",
    "sorting",
    "sorter"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "homepage": "https://github.com/Lionad-Morotar/anysort",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lionad-Morotar/anysort.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  }
}
