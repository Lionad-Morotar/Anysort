{
  "name": "@anysort/nuxt",
  "version": "0.1.0",
  "description": "Nuxt module for Anysort — auto-import useAnysort + runtimeConfig default orders/delim",
  "license": "MIT",
  "type": "module",
  "main": "./dist/module.mjs",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "dev:prepare": "nuxt-module-build prepare --stub",
    "test": "pnpm --filter playground-nuxt exec nuxt prepare && vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@anysort/core": "workspace:*",
    "@anysort/vue": "workspace:*",
    "@nuxt/kit": "^4.4.8"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.8",
    "@nuxt/test-utils": "^4.0.3",
    "nuxt": "^4.4.8",
    "typescript": "^5.9.0",
    "happy-dom": "^20.0.11"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "sort",
    "anysort",
    "auto-import"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "homepage": "https://github.com/Lionad-Morotar/anysort",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lionad-Morotar/anysort.git",
    "directory": "packages/nuxt"
  },
  "publishConfig": {
    "access": "public"
  }
}
