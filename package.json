{
  "name": "anysort-typed",
  "description": "Flexible and Full Typed multi-properties sorter for nested objects",
  "version": "3.4.0",
  "homepage": "https://github.com/Lionad-Morotar/anysort",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lionad-Morotar/anysort.git"
  },
  "license": "MIT",
  "main": "build/index.esm.min.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/index.esm.min.js",
      "require": "./build/index.cjs.min.js",
      "types": "./types/index.d.ts"
    },
    "./types": "./types/index.d.ts",
    "./*": "./*"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json",
    "test": "vitest run",
    "eslint": "oxlint .",
    "coverage:badge": "coverage-badge-creator",
    "watch:test": "vitest"
  },
  "files": [
    "build/**/*",
    "types/**/*",
    "README.md",
    "statics/*"
  ],
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "coverage-badge-creator": "^2.2.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "terser": "^5.49.0",
    "tslib": "^2.8.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "any",
    "array",
    "multiple",
    "nested",
    "object",
    "order",
    "multi-properties",
    "property",
    "sort",
    "sorting",
    "sorter"
  ],
  "engines": {
    "node": ">=20.19",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.15.0"
}
